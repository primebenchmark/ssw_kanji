# Normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly handle common file types
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.swift text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
